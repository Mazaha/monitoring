    format='%(asctime)s [%(levelname)s] %(message)s',
    handlers=[logging.StreamHandler()]
)
logger = logging.getLogger(__name__)

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------
SPLUNK_EARLIEST = "-1d@d"
SPLUNK_LATEST = "@d"

ES_INDEX_COLLECT = "collect_splunk_ip"
ES_INDEX_DALI = "dali_servers"

OUTPUT_CSV = "oracle_static_collection_status.csv"
OUTPUT_XLSX = OUTPUT_CSV.replace(".csv", ".xlsx")

DB_TABLE = "mon_oracle_static_daily"
TABLE_SCHEMA = f"""
    CREATE TABLE IF NOT EXISTS {DB_TABLE} (
        id SERIAL PRIMARY KEY,
        date TIMESTAMP,
        domain VARCHAR NOT NULL,
        device VARCHAR NOT NULL,
        collected BOOLEAN NOT NULL
    );
"""

MAIL_FROM = 'watchsoc@socgen.com'
MAIL_TO = ['WORLD-LGC-DB-ORACLE@socgen.com']
MAIL_SUBJECT = "Automatic reports - [MALDIVES] Oracle static"
MAIL_BODY = "CSV report in attachment<br><br>"

# Exclusion list — devices in blackout/backup/dataguard down are excluded
EXCLUSION_KEY = "dataguard_down_blackout_backup"

# ---------------------------------------------------------------------------
# Disable SSL warnings
# ---------------------------------------------------------------------------
urllib3.disable_warnings(category=urllib3.exceptions.InsecureRequestWarning)

